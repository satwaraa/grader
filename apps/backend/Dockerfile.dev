# Development Dockerfile for Backend
FROM oven/bun:1

WORKDIR /app

# Copy package files
COPY package.json bun.lockb* ./
COPY prisma ./prisma/

# Install dependencies
RUN bun install

# Generate Prisma Client
RUN bunx prisma generate

# Expose port
EXPOSE 3000

# Start in watch mode
CMD ["bun", "run", "--watch", "index.ts"]
