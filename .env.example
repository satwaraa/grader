# =============================================================================
# GRADER - Sample Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# This file documents ALL environment variables required to run the project.
# Lines starting with # are comments and are ignored.
# =============================================================================


# =============================================================================
# POSTGRESQL DATABASE
# =============================================================================
# Credentials for the Postgres container (used by docker-compose)
POSTGRES_DB=grader_db
POSTGRES_USER=grader_user
POSTGRES_PASSWORD=supersecretpassword

# Postgres port exposed on the host (docker-compose maps this to 5432 internally)
POSTGRES_PORT=15432

# Full Prisma connection string used by the backend and worker
# For local dev (without Docker): postgresql://<user>:<password>@localhost:<POSTGRES_PORT>/<db>
# For Docker Compose: postgresql://<user>:<password>@postgres:5432/<db>
DATABASE_URL=postgresql://grader_user:supersecretpassword@localhost:15432/grader_db


# =============================================================================
# BACKEND API SERVER
# =============================================================================
# Port the HTTP API server listens on (default: 8600)
HTTP_PORT=8600

# Allowed CORS origins for the Socket.IO WebSocket server.
# Use "*" to allow all origins (development only).
# In production, set to your frontend domain, e.g. https://app.yourdomain.com
CORS_ORIGIN=http://localhost:5173


# =============================================================================
# WEBSOCKET SERVER (Standalone)
# =============================================================================
# Port for the standalone WebSocket / Socket.IO server (default: 9000).
# Used by ws-server.ts and the ws Docker service.
WS_PORT=9000


# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Secret used to sign access tokens — use a long, random string in production
JWT_SECRET=change-me-use-a-long-random-secret-string

# Secret used to sign refresh tokens — must be different from JWT_SECRET
JWT_REFRESH_SECRET=change-me-use-a-different-long-random-secret

# Access token expiry (e.g. 15m, 1h, 24h)
JWT_EXPIRES_IN=15m

# Refresh token expiry (e.g. 7d, 30d)
JWT_REFRESH_EXPIRES_IN=7d


# =============================================================================
# CLOUDFLARE R2 / S3-COMPATIBLE OBJECT STORAGE
# =============================================================================
# Endpoint URL for your Cloudflare R2 bucket (or any S3-compatible provider)
# Format: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Name of the R2 / S3 bucket where assignment PDFs are stored
BUCKET_NAME=grader-submissions

# R2 API token value (used when generating presigned URLs via the token auth flow)
TOKEN_VALUE=your-r2-api-token-value

# R2 Access Key ID (from Cloudflare R2 → Manage R2 API Tokens)
ACCESSKEYID=your-r2-access-key-id

# R2 Secret Access Key
SECRETACCESSKEY=your-r2-secret-access-key

# Public base URL for accessing stored files (e.g. a custom domain or the R2 public URL)
# Used to construct public download links for submitted PDFs
PUBLIC_ENDPOINT=https://pub-<hash>.r2.dev


# =============================================================================
# REDIS (BullMQ + Pub/Sub)
# =============================================================================
# Redis connection URL used by BullMQ workers and the Socket.IO pub/sub bridge.
# For local dev: redis://localhost:16379
# For Docker Compose: redis://redis:6379
REDIS_URL=redis://localhost:16379


# =============================================================================
# GROQ AI
# =============================================================================
# API key for the Groq models used by the Python grading script.
# Text grading: llama-3.3-70b-versatile
# Image OCR:    meta-llama/llama-4-scout-17b-16e-instruct
# Obtain from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key


# =============================================================================
# FRONTEND (Vite)
# =============================================================================
# These variables are only needed if you want to override the default URLs
# that the frontend uses in development mode.
# They must be prefixed with VITE_ to be exposed to the Vite build.
# Defaults (when not set): http://localhost:8600/api and http://localhost:8600

# Backend API base URL (include /api suffix)
VITE_API_URL=http://localhost:8600/api

# WebSocket server URL (omit /api suffix)
VITE_WS_URL=http://localhost:9000


# =============================================================================
# NODE / RUNTIME
# =============================================================================
# Application environment. Affects logging verbosity and Prisma query logging.
# Values: development | production
NODE_ENV=development
